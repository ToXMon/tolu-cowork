# Tolu Cowork — Environment Configuration
# Copy to .env and fill in your values

# ─── Required ──────────────────────────────────────────────────────────────────
# LLM Provider API key
TOLU_API_KEY=sk-your-api-key-here

# ─── Provider Settings ────────────────────────────────────────────────────────
# Base URL for OpenAI-compatible API
TOLU_BASE_URL=https://api.openai.com/v1
# Model to use
TOLU_MODEL=gpt-4o

# ─── Security ──────────────────────────────────────────────────────────────────
# Encryption key for API key storage (auto-generated if empty)
TOLU_ENCRYPTION_KEY=
# Log level: debug, info, warn, error, silent
TOLU_LOG_LEVEL=info

# ─── Sandbox ───────────────────────────────────────────────────────────────────
# Sandbox level: none, path-only, docker
TOLU_SANDBOX_LEVEL=path-only

# ─── Workspace ─────────────────────────────────────────────────────────────────
# Root workspace directory
TOLU_WORKSPACE=./workspace

# ─── TLS (Optional) ───────────────────────────────────────────────────────────
# Path to TLS certificate
TOLU_TLS_CERT=
# Path to TLS private key
TOLU_TLS_KEY=

# ─── Docker Compose ───────────────────────────────────────────────────────────
# Core service ports
TOLU_PORT=50051
TOLU_WS_PORT=8080

# Redis
TOLU_REDIS_PORT=6379
TOLU_REDIS_PASSWORD=change-me-in-production

# PostgreSQL
TOLU_PG_PORT=5432
TOLU_PG_PASSWORD=change-me-in-production
