    "@grpc/proto-loader": "^0.7.0",
    "duck-duck-scrape": "^2.2.5",
    "node-cron": "^3.0.3",
    "glob": "^11.0.0",
    "yaml": "^2.4.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "vitest": "^3.0.0"
  }
