{
  "name": "@tolu/cowork-core",
  "version": "0.1.0",
  "description": "Open-source Claude Cowork alternative - works with any OpenAI-compatible API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tolu": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
